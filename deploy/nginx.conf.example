# /etc/nginx/sites-available/hostelizetu.com
# Reverse proxy for the Hosteli Zetu Node app (PM2 or docker-compose on 127.0.0.1:5000)

server {
    listen 80;
    server_name hostelizetu.com www.hostelizetu.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name hostelizetu.com www.hostelizetu.com;

    # Managed by certbot, e.g.: certbot --nginx -d hostelizetu.com -d www.hostelizetu.com
    ssl_certificate     /etc/letsencrypt/live/hostelizetu.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hostelizetu.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    client_max_body_size 4m;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;

    # M-Pesa's callback needs a generous timeout — Safaricom can be slow to POST.
    location /api/mpesa/callback {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
